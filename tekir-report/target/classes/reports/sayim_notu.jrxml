<?xml version="1.0" encoding="UTF-8"?>
<jasperReport xmlns="http://jasperreports.sourceforge.net/jasperreports" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://jasperreports.sourceforge.net/jasperreports http://jasperreports.sourceforge.net/xsd/jasperreport.xsd" name="countNoteReport" pageWidth="595" pageHeight="842" whenNoDataType="AllSectionsNoDetail" columnWidth="535" leftMargin="30" rightMargin="30" topMargin="20" bottomMargin="20">
	<property name="ireport.scriptlethandling" value="0"/>
	<property name="ireport.encoding" value="UTF-8"/>
	<property name="ireport.zoom" value="1.0"/>
	<property name="ireport.x" value="0"/>
	<property name="ireport.y" value="0"/>
	<import value="net.sf.jasperreports.engine.*"/>
	<import value="java.util.*"/>
	<import value="net.sf.jasperreports.engine.data.*"/>
	<style name="Defaulf" isDefault="true" isBlankWhenNull="true" fontName="Lucida Sans" fontSize="9" pdfEncoding="Cp1254"/>
	<parameter name="pId" class="java.lang.Long">
		<defaultValueExpression><![CDATA[null]]></defaultValueExpression>
	</parameter>
	<parameter name="TENANT_ID" class="java.lang.String"/>
    <parameter name="pProductLabel" class="java.lang.String" isForPrompting="false"/>
	<queryString>
		<![CDATA[select cn.code, cn.date as txn_date, cn.info,
       wh.name as warehouse_name,
       p.name as product_name, p.code as product_code,
       cni.count_quantity, cni.existing_quantity,
       (cni.count_quantity - cni.existing_quantity) as diff_quantity
from COUNT_NOTE cn
inner join WAREHOUSE wh on wh.id = cn.warehouse_id
inner join COUNT_NOTE_ITEM cni on cni.owner_id = cn.id
inner join PRODUCT p on p.id = cni.product_id
where cn.id = $P{pId} and cn.TENANT_ID = $P{TENANT_ID}]]>
	</queryString>
	<field name="code" class="java.lang.String"/>
	<field name="txn_date" class="java.sql.Date"/>
	<field name="info" class="java.lang.String"/>
	<field name="warehouse_name" class="java.lang.String"/>
	<field name="product_name" class="java.lang.String"/>
	<field name="product_code" class="java.lang.String"/>
	<field name="count_quantity" class="java.math.BigDecimal"/>
	<field name="existing_quantity" class="java.math.BigDecimal"/>
	<field name="diff_quantity" class="java.math.BigDecimal"/>
	<background>
		<band splitType="Stretch"/>
	</background>
	<title>
		<band height="80" splitType="Stretch">
			<staticText>
				<reportElement key="staticText" x="0" y="0" width="535" height="24"/>
				<textElement textAlignment="Center" verticalAlignment="Middle">
					<font fontName="Lucida Sans" size="14" isBold="true" pdfFontName="Helvetica-Bold" pdfEncoding="Cp1254"/>
				</textElement>
				<text><![CDATA[SAYIM FİŞİ]]></text>
			</staticText>
            <textField>
                <reportElement x="0" y="30" width="535" height="15"/>
                <textElement textAlignment="Center"/>
                <textFieldExpression class="java.lang.String"><![CDATA[$F{warehouse_name}]]></textFieldExpression>
            </textField>
            <staticText>
                <reportElement x="0" y="50" width="50" height="15"/>
                <textElement isBold="true"/>
                <text><![CDATA[Fiş No:]]></text>
            </staticText>
            <textField>
                <reportElement x="50" y="50" width="100" height="15"/>
                <textFieldExpression class="java.lang.String"><![CDATA[$F{code}]]></textFieldExpression>
            </textField>
            <staticText>
                <reportElement x="350" y="50" width="50" height="15"/>
                <textElement isBold="true"/>
                <text><![CDATA[Tarih:]]></text>
            </staticText>
            <textField pattern="dd/MM/yyyy">
                <reportElement x="400" y="50" width="100" height="15"/>
                <textFieldExpression class="java.util.Date"><![CDATA[$F{txn_date}]]></textFieldExpression>
            </textField>
            <staticText>
                <reportElement x="0" y="65" width="50" height="15"/>
                <textElement isBold="true"/>
                <text><![CDATA[Açıklama:]]></text>
            </staticText>
            <textField>
                <reportElement x="50" y="65" width="485" height="15"/>
                <textFieldExpression class="java.lang.String"><![CDATA[$F{info}]]></textFieldExpression>
            </textField>
		</band>
	</title>
	<columnHeader>
		<band height="20" splitType="Stretch">
            <line>
                <reportElement x="0" y="19" width="535" height="1"/>
            </line>
			<staticText>
				<reportElement x="0" y="0" width="80" height="15"/>
				<textElement isBold="true"><font pdfFontName="Helvetica-Bold"/></textElement>
				<text><![CDATA[Ürün Kodu]]></text>
			</staticText>
			<staticText>
				<reportElement x="80" y="0" width="200" height="15"/>
				<textElement isBold="true"><font pdfFontName="Helvetica-Bold"/></textElement>
				<text><![CDATA[Ürün Adı]]></text>
			</staticText>
			<staticText>
				<reportElement x="280" y="0" width="80" height="15"/>
				<textElement textAlignment="Right" isBold="true"><font pdfFontName="Helvetica-Bold"/></textElement>
				<text><![CDATA[Mevcut]]></text>
			</staticText>
            <staticText>
				<reportElement x="360" y="0" width="80" height="15"/>
				<textElement textAlignment="Right" isBold="true"><font pdfFontName="Helvetica-Bold"/></textElement>
				<text><![CDATA[Sayılan]]></text>
			</staticText>
            <staticText>
				<reportElement x="440" y="0" width="80" height="15"/>
				<textElement textAlignment="Right" isBold="true"><font pdfFontName="Helvetica-Bold"/></textElement>
				<text><![CDATA[Fark]]></text>
			</staticText>
		</band>
	</columnHeader>
	<detail>
		<band height="18" splitType="Stretch">
			<textField>
				<reportElement x="0" y="0" width="80" height="15"/>
				<textFieldExpression class="java.lang.String"><![CDATA[$F{product_code}]]></textFieldExpression>
			</textField>
			<textField>
				<reportElement x="80" y="0" width="200" height="15"/>
				<textFieldExpression class="java.lang.String"><![CDATA[$F{product_name}]]></textFieldExpression>
			</textField>
            <textField pattern="#,##0.00">
				<reportElement x="280" y="0" width="80" height="15"/>
				<textElement textAlignment="Right"/>
				<textFieldExpression class="java.math.BigDecimal"><![CDATA[$F{existing_quantity}]]></textFieldExpression>
			</textField>
             <textField pattern="#,##0.00">
				<reportElement x="360" y="0" width="80" height="15"/>
				<textElement textAlignment="Right"/>
				<textFieldExpression class="java.math.BigDecimal"><![CDATA[$F{count_quantity}]]></textFieldExpression>
			</textField>
             <textField pattern="#,##0.00">
				<reportElement x="440" y="0" width="80" height="15"/>
				<textElement textAlignment="Right"/>
				<textFieldExpression class="java.math.BigDecimal"><![CDATA[$F{diff_quantity}]]></textFieldExpression>
			</textField>
		</band>
	</detail>
	<pageFooter>
		<band height="20" splitType="Stretch">
			<textField>
				<reportElement x="435" y="0" width="80" height="20"/>
				<textElement textAlignment="Right"/>
				<textFieldExpression class="java.lang.String"><![CDATA["Sayfa "+$V{PAGE_NUMBER}+" /"]]></textFieldExpression>
			</textField>
			<textField evaluationTime="Report">
				<reportElement x="515" y="0" width="40" height="20"/>
				<textFieldExpression class="java.lang.String"><![CDATA[" " + $V{PAGE_NUMBER}]]></textFieldExpression>
			</textField>
            <textField pattern="" isBlankWhenNull="true">
				<reportElement key="textField-9" mode="Transparent" x="0" y="0" width="239" height="13" forecolor="#666666"/>
				<textElement textAlignment="Justified" verticalAlignment="Middle">
					<font fontName="Lucida Sans" size="7" isBold="true" isItalic="false" pdfEncoding="Cp1254"/>
				</textElement>
				<textFieldExpression class="java.lang.String"><![CDATA[$P{pProductLabel}]]></textFieldExpression>
			</textField>
		</band>
	</pageFooter>
</jasperReport>
